@startuml 04 - Odeme Sureci Aktivite Diyagrami

skinparam activityFontSize 13
skinparam activityArrowFontSize 11
skinparam activityBackgroundColor #FDFEFE
skinparam activityBorderColor #555555
skinparam partitionBackgroundColor #F4F6F7
skinparam ArrowColor #333333
skinparam noteBackgroundColor #FFFDE7

title Г–deme SГјreci Aktivite DiyagramДұ

|Veznedar|
start

:Sisteme giriЕҹ yapar\n(POST /api/auth/login);

:Randevu ID girer\n(POST /api/veznedar/randevu/{id}/odeme);

|Sistem|

:Randevuyu veritabanДұndan getirir\n(RandevuRepository.findById);

if (Randevu bulunamadДұ?) then (evet)
  :404 EntityNotFoundException\n"Randevu bulunamadДұ";
  |Veznedar|
  :ID'yi kontrol eder;
  stop
endif

if (randevu.odendi == true?) then (evet)
  :400 IllegalArgumentException\n"Bu randevunun Г¶demesi\nzaten alДұnmДұЕҹ";
  |Veznedar|
  stop
endif

:HastanДұn TCKN bilgisini alДұr\n(randevu.hasta.iletisimBilgisi.tckno);

|Sigorta Servisi|

:Sigorta indirim oranДұnДұ sorgular\n(SigortaService.indirimOraniSorgula(tckno));

:indirimOrani dГ¶ner\n(0.0 вҶ’ 1.0 arasДұ);

|Sistem|

:Doktor muayene Гјcretini hesaplar\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nmuayeneUcreti =\n  (sureDakika / 60) Г— doktor.hourlyRate\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nUnvan вҶ’ saatlik Гјcret:\n  INTERN:             50  вӮә/saat\n  RESIDENT:           75  вӮә/saat\n  SPECIALIST:        100  вӮә/saat\n  ASSOCIATE_PROFESSOR: 150 вӮә/saat\n  PROFESSOR:         200  вӮә/saat;

:Tedavi Гјcretlerini toplar\n(ОЈ tedaviUcreti)\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nAMELД°YAT:       5.000 вӮә\nД°LAГҮ_TEDAVД°SД°:    750 вӮә\nFД°ZД°K_TEDAVД°:   1.500 вӮә\nSERVД°S_YATIЕһ:   2.000 вӮә;

:BrГјt Гјcreti hesaplar\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nbrutUcret =\n  muayeneUcreti + ОЈ tedaviUcreti\n(yuvarla 2 ondalДұk - HALF_UP);

if (indirimOrani > 0?) then (evet)
  :Sigorta indirimi uygular\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nodenecekUcret =\n  brutUcret Г— (1 вҲ’ indirimOrani)\n(yuvarla 2 ondalДұk - HALF_UP);
else (hayДұr)
  :odenecekUcret = brutUcret;
endif

:Randevu gГјncellenir\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nrandevu.sigortaIndirimOrani = indirimOrani\nrandevu.ucret = odenecekUcret\nrandevu.odendi = true;

:Randevu kaydedilir\n(RandevuRepository.save);

:200 OK\nRandevuOdemeDTO dГ¶ner\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nrandevuId, hasta adДұ\nbrГјtГңcret, indirimOrani\nГ¶denecekГңcret, odendi;

|Veznedar|
:Г–deme bilgilerini gГ¶rГјr\nMakbuzu hazДұrlar;

stop

note right
  Г–deme alДұndДұktan sonra:
  - randevu.odendi = true
  - Doktor sureDakika ve tedavi
    gГјncellemesi yapAMAZ
  - Tekrar Г¶deme isteДҹi вҶ’ 400 hatasДұ
end note

@enduml
