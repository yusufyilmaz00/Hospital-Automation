@startuml Hospital-Automation OOD Sinif Diyagrami

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageStyle rectangle
skinparam linetype polyline
skinparam nodesep 50
skinparam ranksep 70
skinparam ArrowColor #444444
skinparam ClassBorderColor #333333
skinparam PackageBorderColor #888888

' ============================================================
'  KATMAN: AUTH / SESSION / SECURITY
' ============================================================

package "auth" #FDEBD0 {

  interface AuthUser << interface >> {
    + getId() : Long
    + getEmail() : String
    + getPassword() : String
    + getUserType() : UserType
  }

  interface "AuthUserRepository<T>" as AuthUserRepository << interface >> {
    + findByEmail(email : String) : Optional<T>
  }

  enum UserType {
    HASTA
    DOKTOR
    KAYIT_GOREVLISI
    RANDEVU_GOREVLISI
    VEZNEDAR
  }

  class AuthService << @Service >> {
    - passwordEncoder : PasswordEncoder
    - sessionService : SessionService
    - authUserService : AuthUserService
    + login(request : AuthRequest) : Session
    - findByEmail(email : String) : Optional<AuthUser>
  }

  class AuthUserService << @Service >> {
    - hastaRepository : HastaRepository
    - doctorRepository : DoctorRepository
    - kayitGorevlisiRepository : KayitGorevlisiRepository
    - randevuGorevlisiRepository : RandevuGorevlisiRepository
    - veznedarRepository : VeznedarRepository
    + getRepository(userType : UserType) : AuthUserRepository<?>
    + getClass(userType : UserType) : Class<? extends AuthUser>
  }

  class AuthController << @RestController >> {
    - authService : AuthService
    - sessionService : SessionService
    + login(request : AuthRequest) : ResponseEntity<LoginResponseDTO>
    + logout() : ResponseEntity<Void>
  }
}

package "session" #D5F5E3 {

  class Session << @Entity >> {
    - id : UUID
    - token : String
    - userId : Long
    - createdAt : LocalDateTime
    - expiresAt : LocalDateTime
    - active : Boolean
    - userType : UserType
  }

  class SessionService << @Service >> {
    - sessionRepository : SessionRepository
    + createSession(user : AuthUser) : Session
    + getByToken(token : String) : Optional<Session>
    + isValid(session : Session) : Boolean
    + invalidate(session : Session) : void
    + invalidateAllUserSessions(userId : Integer) : void
  }

  interface SessionRepository << JpaRepository >> {
    + findByToken(token : String) : Optional<Session>
    + findAllByUserIdAndActiveTrue(userId : Integer) : List<Session>
  }
}

package "security" #D6EAF8 {

  class SessionAuthFilter << @Component >> {
    - sessionService : SessionService
    - authUserService : AuthUserService
    # doFilterInternal(req, res, chain) : void
    - getSession(token : String) : Optional<Session>
    - setAuth(session : Session) : void
  }

  class SecurityContextUtil << utility >> {
    + {static} set(userId : Long, userType : UserType) : void
    + {static} currentUser(clazz : Class<T>) : Optional<Long>
  }

  class CookieUtil << utility >> {
    + {static} getCookie(request, name : String) : Optional<String>
    + {static} addCookie(response, name, value, maxAge) : void
    + {static} deleteCookie(response, name) : void
  }
}

' ============================================================
'  KATMAN: DOMAIN - COMMON
' ============================================================

package "common" #F9F3E3 {

  class IletisimBilgisi << @Entity >> {
    - id : Integer
    - isim : String
    - soyisim : String
    - tckno : String
    - telefon : String
    - adres : String
    - dogumTarihi : LocalDate
  }

  interface IletisimBilgisiRepository << JpaRepository >> {
  }

  class IletisimBilgisiMapper << @Component >> {
    + toEntity(dto : IletisimBilgisiDTO) : IletisimBilgisi
    + toDTO(entity : IletisimBilgisi) : IletisimBilgisiDTO
  }
}

' ============================================================
'  KATMAN: DOMAIN - PERSONEL
' ============================================================

package "personel" #E8DAEF {

  abstract class Personel << @MappedSuperclass >> {
    - id : Long
    - email : String
    - password : String
    - contactInformation : IletisimBilgisi
  }

  class KayitGorevlisi << @Entity >> {
    + getUserType() : UserType
  }

  class RandevuGorevlisi << @Entity >> {
    + getUserType() : UserType
  }

  class Veznedar << @Entity >> {
    + getUserType() : UserType
  }

  class Doktor << @Entity >> {
    - department : Bolum
    - unvan : Unvan
    - activeReservations : List<Randevu>
    + getUserType() : UserType
  }

  enum Bolum {
    CARDIOLOGY
    NEUROLOGY
    ORTHOPEDICS
    PEDIATRICS
    DERMATOLOGY
  }

  enum Unvan {
    INTERN
    RESIDENT
    SPECIALIST
    ASSOCIATE_PROFESSOR
    PROFESSOR
  }
}

