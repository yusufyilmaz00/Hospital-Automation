' ============================================================
'  KALITIM & INTERFACE GERÇEKLEMELERI
' ============================================================

Personel    ..|> AuthUser
Hasta       ..|> AuthUser

KayitGorevlisi    --|> Personel
RandevuGorevlisi  --|> Personel
Veznedar          --|> Personel
Doktor            --|> Personel

HastaRepository    --|> AuthUserRepository
DoctorRepository   --|> AuthUserRepository
KayitGorevlisiRepository   --|> AuthUserRepository
RandevuGorevlisiRepository --|> AuthUserRepository
VeznedarRepository         --|> AuthUserRepository

HastaServiceImpl          ..|> HastaService
DoctorServiceImpl         ..|> DoctorService
KayitGorevlisiServiceImpl ..|> KayitGorevlisiService
RandevuGorevlisiServiceImpl ..|> RandevuGorevlisiService
VeznedarServiceImpl       ..|> VeznedarService
RandevuServiceImpl        ..|> RandevuService

' ============================================================
'  ENTITY İLİŞKİLERİ
' ============================================================

Personel "1" *-- "1" IletisimBilgisi
Hasta    "1" *-- "1" IletisimBilgisi

Hasta  "1" *-- "0..*" Hastalik  : hastaliklar
Hasta  "1" *-- "0..*" Randevu   : randevular
Doktor "1" *-- "0..*" Randevu   : activeReservations

Randevu "1" *-- "0..*" Tedavi   : tedaviler
Tedavi  "1" *-- "0..*" Recete   : receteler
Rapor "0..*" --> "1"   Randevu

Doktor  --> Bolum
Doktor  --> Unvan
Tedavi  --> TedaviTipi
Session --> UserType

' ============================================================
'  KATMANLAR ARASI BAĞIMLILIKLAR
' ============================================================

' Controllers → Services
AuthController               ..> AuthService
AuthController               ..> SessionService
HastaController              ..> HastaService
DoktorController             ..> DoctorService
KayitGorevlisiController     ..> KayitGorevlisiService
RandevuGorevlisiController   ..> RandevuGorevlisiService
RandevuGorevlisiController   ..> DoctorService
VeznedarController           ..> VeznedarService
VeznedarController           ..> RandevuService

' Services → Repositories
HastaServiceImpl         ..> HastaRepository
HastaServiceImpl         ..> HastalikRepository
HastaServiceImpl         ..> IletisimBilgisiRepository
DoctorServiceImpl        ..> DoctorRepository
DoctorServiceImpl        ..> HastaService
DoctorServiceImpl        ..> RandevuRepository
DoctorServiceImpl        ..> RaporRepository
DoctorServiceImpl        ..> ReceteRepository
KayitGorevlisiServiceImpl ..> KayitGorevlisiRepository
KayitGorevlisiServiceImpl ..> HastaService
RandevuGorevlisiServiceImpl ..> RandevuGorevlisiRepository
RandevuGorevlisiServiceImpl ..> HastaService
RandevuGorevlisiServiceImpl ..> DoctorService
RandevuServiceImpl       ..> RandevuRepository
VeznedarServiceImpl      ..> VeznedarRepository

' Auth / Session bağımlılıkları
AuthService ..> SessionService
AuthService ..> AuthUserService
AuthUserService ..> HastaRepository
AuthUserService ..> DoctorRepository
AuthUserService ..> KayitGorevlisiRepository
AuthUserService ..> RandevuGorevlisiRepository
AuthUserService ..> VeznedarRepository
SessionService ..> SessionRepository

' Security filter bağımlılıkları
SessionAuthFilter ..> SessionService
SessionAuthFilter ..> AuthUserService
SessionAuthFilter ..> SecurityContextUtil

@enduml
