package "personel.doktor" #EBF5FB {

  interface DoctorService << interface >> {
    + createDoktor(dto : DoktorCreateDTO) : Doktor
    + getAllDoctors() : List<Doktor>
    + getDoctorById(id : Long) : Doktor
    + getActiveReservations(doctorId : Long) : List<Randevu>
    + addReservation(doctorId, time, hasta) : Randevu
    + removeReservation(doctorId, randevuId : Long) : void
    + checkAvailability(doctorId, time) : boolean
    + isAvailable(doctorId, start, end, interval) : List<LocalDateTime>
    + getMyRandevular(doktorId : Long) : List<DoktorRandevuDTO>
    + getHastaByRandevuId(doktorId, randevuId : Long) : HastaResponseDTO
    + addTedavi(doktorId, randevuId, dto) : HastaTedaviDTO
    + removeTedavi(doktorId, randevuId, tedaviId : Long) : void
    + addRecete(doktorId, randevuId, tedaviId, dto) : ReceteDTO
    + removeRecete(doktorId, randevuId, tedaviId, receteId : Long) : void
    + addRapor(doktorId, randevuId, dto) : RaporResponseDTO
    + removeRapor(doktorId, randevuId, raporId : Long) : void
    + updateHastaBoy(doktorId, hastaId, boy) : void
    + updateHastaKilo(doktorId, hastaId, kilo) : void
    + addHastalik(doktorId, hastaId, detay) : void
    + updateHastalik(doktorId, hastaId, hastalikId, detay) : void
    + deleteHastalik(doktorId, hastaId, hastalikId : Long) : void
  }

  class DoctorServiceImpl << @Service >> {
    - doctorRepository : DoctorRepository
    - hastaService : HastaService
    - randevuRepository : RandevuRepository
    - raporRepository : RaporRepository
    - receteRepository : ReceteRepository
    - iletisimMapper : IletisimBilgisiMapper
    - passwordEncoder : PasswordEncoder
  }

  interface DoctorRepository << AuthUserRepository<Doktor> >> {
  }

  class DoktorController << @RestController >> {
    - doctorService : DoctorService
    - doktorMapper : DoktorMapper
    + doktorKaydet(dto) : ResponseEntity<DoktorResponseDTO>
    + doktorlariListele() : ResponseEntity<List<DoktorResponseDTO>>
    + randevulariListele() : ResponseEntity<List<DoktorRandevuDTO>>
    + hastayiGor(randevuId) : ResponseEntity<HastaResponseDTO>
    + tedaviEkle(randevuId, dto) : ResponseEntity<HastaTedaviDTO>
    + tedaviSil(randevuId, tedaviId) : ResponseEntity<Void>
    + receteEkle(randevuId, tedaviId, dto) : ResponseEntity<ReceteDTO>
    + receteSil(randevuId, tedaviId, receteId) : ResponseEntity<Void>
    + raporEkle(randevuId, dto) : ResponseEntity<RaporResponseDTO>
    + raporSil(randevuId, raporId) : ResponseEntity<Void>
    + hastalikEkle(hastaId, dto) : ResponseEntity<Void>
    + hastalikGuncelle(hastaId, hastalikId, dto) : ResponseEntity<Void>
    + hastalikSil(hastaId, hastalikId) : ResponseEntity<Void>
  }

  class DoktorMapper << @Component >> {
    + toDTO(doktor : Doktor) : DoktorResponseDTO
  }
}

